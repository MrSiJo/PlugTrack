# PlugTrack runtime configuration.
#
# Copy to `.env` (gitignored) and fill in real values. APP_SECRET_KEY is
# the only mandatory secret — generate it with e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Hard requirements enforced at startup (see backend/plugtrack/bootstrap.py):
#   - APP_SECRET_KEY must be at least 32 characters long.
#   - APP_SECRET_KEY must NOT contain known placeholder fragments
#     ("replace-with", "change-me", "your-secret", "placeholder") — the
#     loader rejects these so the default value below cannot ship as-is.
#
# ⚠ ROTATION IS DESTRUCTIVE. APP_SECRET_KEY is BOTH the session-cookie signer
# AND the key that encrypts secrets at rest (Telegram/OpenAI tokens, car VINs)
# — the Fernet key is derived as sha256(APP_SECRET_KEY). There is no key
# versioning, so changing this value permanently orphans every previously
# encrypted value (they will fail to decrypt) and invalidates all sessions.
# To rotate safely: decrypt/clear the encrypted settings + VINs under the old
# key first, change the key, then re-enter those secrets.

APP_SECRET_KEY=replace-me-with-a-long-random-string-at-least-32-chars

# SQLite + aiosqlite. The path is inside the container; the host bind
# mount in compose.yaml puts it at /dockerdata/plugtrack/data.
DATABASE_URL=sqlite+aiosqlite:////app/data/plugtrack.db

# Secure-by-default: cookies carry the Secure flag unless this is set to
# "false". Leave it at the default (true) in any HTTPS deployment (e.g.
# behind Caddy/nginx terminating TLS in front of compose). Set it to
# "false" ONLY for plain-HTTP localhost dev, since browsers reject Secure
# cookies over http://.
COOKIE_SECURE=true

# MCP transport security (DNS-rebinding protection for /mcp).
#
# The MCP SDK (>= 1.23) can validate the Host header on /mcp requests and
# answer HTTP 421 for anything not allowlisted.
#
# UNSET / EMPTY (the default): validation is DISABLED. This is the right
# setting for the usual LAN deployment — the app is reached through a
# reverse proxy (nginx proxy manager) on an internal FQDN that a static
# allowlist can't anticipate, and /mcp is already protected by bearer-token
# auth, so DNS-rebinding protection adds little on a trusted network.
#
# SET (comma-separated Host values): validation is ENABLED strictly with
# exactly this allowlist. A bare hostname entry (no port) matches with or
# without a port; an entry with an explicit port matches only that port;
# "host:*" matches any explicit port. Example:
#   MCP_ALLOWED_HOSTS=plugtrack.internal.lan,localhost,127.0.0.1
#MCP_ALLOWED_HOSTS=
