# ========================================
# PlugTrack Specific
# ========================================
# Keep demo credentials in code but ensure they're not production secrets
# Demo credentials are intentionally included for first-time setup

docs/project/*
.cursor/*

# ========================================
# v2 rebuild — Phase 0 pycupra discovery harness
# ========================================
# Probe output and the rendered findings document may contain personal data
# (account info, VINs, GPS, raw API responses). Keep docs/ out of git.
# Already-tracked files (e.g. docs/superpowers/, docs/assets/) remain tracked
# because gitignore does not retroactively untrack files in the index.
docs/
.env.probe

# Local screenshots (charge-history / app captures) — personal data, never commit.
snapshots/

# v2 rebuild — legacy Flask app preserved on disk for reference, not tracked
legacy/

# pycupra discovery harness output (Phase 0)
scripts/probe_output/

# pycupra runtime cache (token + per-VIN car images) — local only, contains VIN/PII.
www/

# pycupra OAuth token cache + credentials — local only, never commit (PII/secrets).
pycupra_data/
*pycupra_credentials.json

# Python (additional)
.ruff_cache/
.mypy_cache/

# Node (additional)
dist/
.vite/

# Brainstorming companion scratch
.superpowers/
.scratch/
